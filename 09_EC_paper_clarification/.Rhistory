# Create individual dataframes
df_A  <- data.frame(gene = test$A,  set = "A")
df_B  <- data.frame(gene = test$B,  set = "B")
df_AB <- data.frame(gene = test$`A:B`, set = "A:B")
# Combine them
combined_df <- rbind(df_A, df_B, df_AB)
View(combined_df)
max_len <- max(length(test$A), length(test$B), length(test$`A:B`))
# Pad each vector to the same length
A_col  <- c(test$A,  rep(NA, max_len - length(test$A)))
B_col  <- c(test$B,  rep(NA, max_len - length(test$B)))
AB_col <- c(test$`A:B`, rep(NA, max_len - length(test$`A:B`)))
# Create a new dataframe
venn_df <- data.frame(
A = A_col,
B = B_col,
A_B = AB_col,
stringsAsFactors = FALSE
)
View(venn_df)
write.csv(venn_df, "venn_gene_lists_4M_UP_and_4M1EV_DOWN.csv", row.names = FALSE)
