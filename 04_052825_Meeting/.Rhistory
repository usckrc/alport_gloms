df <- df %>%
kbl(caption = paste("Top 20", i, "Genes Upregulated in 4M_Alports")) %>%
kable_styling(bootstrap_options = c("striped", "hover"), font_size = 20)
print(df)
top5 <- head(DEGs$gene, 5)
for (j in top5) {
A <- VlnPlot(SO, j, idents = i, split.by = "group")
print(A)
}
}
SO2 <- subset(SO, subset = group == "4M_Alp")
clusters <- unique(SO2@meta.data$class_merge)
clusters <- unique(SO2@meta.data$class_merge)
names(clusters) <- clusters
SO2 <- subset(SO, subset = group == "4M_Alp")
clusters <- unique(SO2@meta.data$class_merge)
names(clusters) <- clusters
SO <- PrepSCTFindMarkers(SO)
DEG.env <- new.env()
Idents(SO) <- SO@meta.data$class_merge
rm(SO2)
for (i in clusters) {
DefaultAssay(SO) <- "SCT"
DEGs <- FindMarkers(SO, ident.1 = "4M_Alp", ident.2 = "WT", group.by = "group" , subset.ident = i, logfc.threshold = .1, min.pct = .1)
DEGs <- DEGs %>% rownames_to_column("gene") %>% filter(p_val < .05)
DEGs <- DEGs[order(DEGs[,"avg_log2FC"], decreasing = TRUE),]
assign(paste0("Alports_4M_",names(clusters[i])), DEGs, envir = DEG.env)
#remove the first column of from the dataframe DEGs
DEGs <- rownames_to_column(DEGs)
DEGs <- DEGs[,-1]
df <- head(DEGs, 20)
df <- df %>%
kbl(caption = paste("Top 20", i, "Genes Upregulated in 4M_Alports")) %>%
kable_styling(bootstrap_options = c("striped", "hover"), font_size = 20)
print(df)
top5 <- head(DEGs$gene, 5)
for (j in top5) {
A <- VlnPlot(SO, j, idents = i, split.by = "group")
print(A)
}
}
list_objects <- ls(DEG.env)
save(list = list_objects, file = here("output", "Alports_4M_Condition_DEGs.Rdata"), envir = DEG.env)
save(list = list_objects, file = here("outputs", "Alports_4M_Condition_DEGs.Rdata"), envir = DEG.env)
custom_order <- clusters
allobj <- ls(DEG.env)
alldf <- sapply(allobj, get, simplify = FALSE, envir = DEG.env)
alldf <- alldf[sapply(alldf, inherits, "data.frame")]
custom_order <- clusters
alldf <- alldf[match(custom_order, names(alldf))]
write.xlsx(alldf, sheetName = names(alldf), file = here("outputs", "Alports_4M_Condition_DEGs.xlsx"))
allobj <- ls(DEG.env)
allobj <- ls(DEG.env)
