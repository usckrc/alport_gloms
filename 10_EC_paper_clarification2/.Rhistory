ident.1 = cl,
min.pct = 0.25
)
# Add gene + cluster columns
deg$gene <- rownames(deg)
deg$cluster <- cl
# Apply filter + sorting
deg <- deg %>%
filter(p_val < 0.05) %>%
arrange(desc(avg_log2FC))
# Reorder columns
deg <- deg[, c("cluster", "gene", setdiff(colnames(deg), c("cluster", "gene")))]
deg_list[[cl]] <- deg
}
# Write to Excel
wb <- createWorkbook()
for (cl in names(deg_list)) {
safe_name <- substr(gsub("[^[:alnum:]_]", "_", cl), 1, 31)
addWorksheet(wb, safe_name)
writeData(wb, safe_name, deg_list[[cl]])
}
saveWorkbook(wb, "DEG_list_filtered_sorted_significant.xlsx", overwrite = TRUE)
